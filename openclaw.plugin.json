{
  "id": "openclaw-thinking-orchestrator",
  "name": "OpenClaw Thinking Orchestrator",
  "version": "1.0.0",
  "description": "Merged execution orchestrator: applies thinking policies and injects a compact execution brief for main-agent tasks.",
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "defaultMode": {
        "type": "string",
        "default": "auto"
      },
      "defaultLevel": {
        "type": "string",
        "default": "low"
      },
      "injectGoalBrief": {
        "type": "boolean",
        "default": true
      },
      "goalMaxConstraints": {
        "type": "number",
        "default": 6
      },
      "minimumLevel": {
        "type": "string",
        "default": "off"
      },
      "maximumLevel": {
        "type": "string"
      },
      "respectExplicitThinkDirective": {
        "type": "boolean",
        "default": true
      },
      "previewFile": {
        "type": "string"
      },
      "goalPreviewFile": {
        "type": "string"
      },
      "autoPolicy": {
        "type": "object"
      },
      "agentRules": {
        "type": "object"
      },
      "modelRules": {
        "type": "object"
      }
    }
  }
}
