{
  "id": "openclaw-thinking-orchestrator",
  "name": "OpenClaw Thinking Orchestrator",
  "version": "2.0.1",
  "description": "Claude-inspired thinking-level decisions with explicit runtime status and no prompt injection.",
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "defaultMode": {
        "type": "string",
        "default": "auto"
      },
      "defaultLevel": {
        "type": "string",
        "default": "low"
      },
      "minimumLevel": {
        "type": "string",
        "default": "off"
      },
      "maximumLevel": {
        "type": "string",
        "default": "high"
      },
      "respectExplicitThinkDirective": {
        "type": "boolean",
        "default": true
      },
      "previewFile": {
        "type": "string"
      },
      "briefsDir": {
        "type": "string"
      },
      "agentRules": {
        "type": "object"
      },
      "modelRules": {
        "type": "object"
      },
      "agentsRoot": {
        "type": "string"
      }
    }
  }
}
